# Copy to .env and fill in. .env is gitignored (from commit #1).
# NEVER commit real values.

# --- Kalshi (READ-ONLY use in Phase 0) ---
KALSHI_KEY_ID=

# The RSA private key downloaded from Kalshi. Two accepted forms:
#
# 1) Escaped single line (best for Railway UI):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
#
# 2) Heredoc block (best for local .env, paste the file verbatim):
# KALSHI_PRIVATE_KEY_PEM=<<PEM
# -----BEGIN RSA PRIVATE KEY-----
# MIIE...
# -----END RSA PRIVATE KEY-----
# PEM
KALSHI_PRIVATE_KEY_PEM=

# --- Optional Kalshi demo env (auth smoke-tested here first when present) ---
KALSHI_DEMO_KEY_ID=
KALSHI_DEMO_PRIVATE_KEY_PEM=

# --- Supabase (worker writes to schema founder_alpha) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Capture config ---
KALSHI_SERIES_TICKER=KXBTC15M
CAPTURE_DRY_RUN=false
