# --- SECRETS: never commit ---
.env
.env.*
!.env.example
# Founder dashboard token, written to a local file for one-time handoff.
dash-token.txt
*token*.txt
# Scratch scripts used for one-off DB checks.
scratch-*.mjs
# Kalshi key material — patterns are case-insensitive-safe on purpose, since
# the downloaded filename casing varies and macOS is case-preserving.
# Deliberately NOT anchored to an extension: editor/shell leftovers such as
# "kalshi-key.txt.save" and "kalshi-key.txt-----BEGIN" were observed in this
# working tree and each held a full private key.
*[Kk][Aa][Ll][Ss][Hh][Ii]*[Kk][Ee][Yy]*
*.pem
*.key
*_rsa
id_*
# Editor backups / partial writes, which routinely capture secret files.
*.save
*.swp
*.bak
*~
*-----BEGIN*

# --- deps ---
node_modules/

# --- private fixtures (may contain account-identifying data) ---
fixtures/private/

# --- local capture artifacts ---
# The macro calendar is a checked-in input, not an artifact: a capture row's
# macro_flag must be re-derivable from the repo at that commit.
data/*
!data/macro-calendar.json
data/capture/
*.sqlite
*.sqlite3
*.db
logs/
*.log

# --- os ---
.DS_Store
